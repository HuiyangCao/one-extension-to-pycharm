{
  "name": "copy-with-ref",
  "displayName": "Copy with File Reference",
  "description": "Copy the current file path and line number reference to clipboard. Select code to get a range (e.g. src/foo.py:10-15), or just place the cursor for a single line ref. Useful for pasting into terminals, AI prompts, or issue trackers.",
  "version": "0.0.1",
  "publisher": "user",
  "repository": {
    "type": "git",
    "url": "https://github.com/HuiyangCao/vscode-copy-with-ref.git"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "keywords": ["copy", "path", "line", "reference", "clipboard"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copy-with-ref.copy",
        "title": "Copy with File Reference"
      },
      {
        "command": "copy-with-ref.openFileFromScm",
        "title": "Open File (No Diff)",
        "icon": "$(go-to-file)"
      },
      {
        "command": "copy-with-ref.copyFilesToSystem",
        "title": "Copy to System Clipboard"
      }
    ],
    "keybindings": [
      {
        "command": "copy-with-ref.copy",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorTextFocus"
      },
      {
        "key": "ctrl+shift+q",
        "command": "editor.debug.action.runToCursor"
      },
      {
        "key": "ctrl+q",
        "command": "-workbench.action.quit"
      },
      {
        "key": "ctrl+q",
        "command": "git.closeAllDiffEditors"
      },
      {
        "key": "ctrl+p",
        "command": "-workbench.action.quickOpen"
      },
      {
        "key": "ctrl+p",
        "command": "-workbench.action.quickOpenNavigateNextInFilePicker",
        "when": "inFilesPicker && inQuickOpen"
      },
      {
        "key": "ctrl+d",
        "command": "-editor.action.addSelectionToNextFindMatch",
        "when": "editorFocus"
      },
      {
        "key": "ctrl+k d",
        "command": "-workbench.files.action.compareWithSaved"
      },
      {
        "key": "ctrl+; d",
        "command": "-jupyter.moveCellsDown",
        "when": "editorTextFocus && jupyter.hascodecells && !jupyter.webExtension && !notebookEditorFocused"
      },
      {
        "key": "ctrl+k ctrl+d",
        "command": "-editor.action.moveSelectionToNextFindMatch",
        "when": "editorFocus"
      },
      {
        "key": "ctrl+d",
        "command": "-notebook.addFindMatchToSelection",
        "when": "config.notebook.multiCursor.enabled && notebookCellEditorFocused && activeEditor == 'workbench.editor.notebook'"
      },
      {
        "key": "ctrl+shift+d",
        "command": "-workbench.view.debug",
        "when": "viewContainer.workbench.view.debug.enabled"
      },
      {
        "key": "ctrl+d",
        "command": "workbench.action.pinEditor",
        "when": "!activeEditorIsPinned"
      },
      {
        "key": "ctrl+k shift+enter",
        "command": "-workbench.action.pinEditor",
        "when": "!activeEditorIsPinned"
      },
      {
        "key": "ctrl+shift+alt+f",
        "command": "editor.action.formatSelection",
        "when": "editorHasDocumentSelectionFormattingProvider && editorTextFocus && !editorReadonly"
      },
      {
        "key": "ctrl+k ctrl+f",
        "command": "-editor.action.formatSelection",
        "when": "editorHasDocumentSelectionFormattingProvider && editorTextFocus && !editorReadonly"
      },
      {
        "key": "shift+enter",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
          "text": "\u001b\r"
        },
        "when": "terminalFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "copy-with-ref.copy",
          "group": "9_cutcopypaste",
          "when": "editorTextFocus"
        }
      ],
      "scm/resourceState/inline": [
        {
          "command": "copy-with-ref.openFileFromScm",
          "when": "scmProvider == git",
          "group": "inline"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "copy-with-ref.openFileFromScm",
          "when": "scmProvider == git",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "copy-with-ref.copyFilesToSystem",
          "group": "5_cutcopypaste",
          "when": "!explorerResourceIsRoot"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
