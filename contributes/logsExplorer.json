{
  "commands": [
    {
      "command": "trainning_extension.setLogsDirectory",
      "title": "Set Logs Directory",
      "icon": "$(folder-opened)"
    },
    {
      "command": "trainning_extension.refreshLogs",
      "title": "Refresh Logs",
      "icon": "$(refresh)"
    },
    {
      "command": "trainning_extension.copyOnnxFiles",
      "title": "Copy",
      "icon": "$(files)"
    },
    {
      "command": "trainning_extension.revealOnnxInExplorer",
      "title": "Reveal in File Explorer"
    },
    {
      "command": "trainning_extension.copyOnnxFilePath",
      "title": "Copy Path"
    }
  ],
  "views": {
    "trainning_extension": [
      {
        "id": "trainning_extension_logs",
        "name": "Logs"
      }
    ]
  },
  "menus": {
    "view/title": [
      {
        "command": "trainning_extension.setLogsDirectory",
        "when": "view == trainning_extension_logs",
        "group": "navigation@1"
      },
      {
        "command": "trainning_extension.refreshLogs",
        "when": "view == trainning_extension_logs",
        "group": "navigation@2"
      },
      {
        "command": "trainning_extension.copyOnnxFiles",
        "when": "view == trainning_extension_logs",
        "group": "navigation@3"
      }
    ],
    "view/item/context": [
      {
        "command": "trainning_extension.copyOnnxFiles",
        "when": "view == trainning_extension_logs && viewItem == onnxFile",
        "group": "inline@1"
      },
      {
        "command": "trainning_extension.copyOnnxFiles",
        "when": "view == trainning_extension_logs && viewItem == onnxFile",
        "group": "navigation@1"
      },
      {
        "command": "trainning_extension.copyOnnxFilePath",
        "when": "view == trainning_extension_logs && viewItem == onnxFile",
        "group": "navigation@2"
      },
      {
        "command": "trainning_extension.revealOnnxInExplorer",
        "when": "view == trainning_extension_logs && viewItem == onnxFile",
        "group": "navigation@3"
      },
      {
        "command": "trainning_extension.copyOnnxFiles",
        "when": "view == trainning_extension_logs && viewItem == runFolder",
        "group": "inline@1"
      },
      {
        "command": "trainning_extension.copyOnnxFiles",
        "when": "view == trainning_extension_logs && viewItem == runFolder",
        "group": "navigation@1"
      },
      {
        "command": "trainning_extension.copyOnnxFilePath",
        "when": "view == trainning_extension_logs && viewItem == runFolder",
        "group": "navigation@2"
      },
      {
        "command": "trainning_extension.revealOnnxInExplorer",
        "when": "view == trainning_extension_logs && viewItem == runFolder",
        "group": "navigation@3"
      },
      {
        "command": "trainning_extension.copyOnnxFiles",
        "when": "view == trainning_extension_logs && viewItem == taskGroup",
        "group": "inline@1"
      },
      {
        "command": "trainning_extension.copyOnnxFiles",
        "when": "view == trainning_extension_logs && viewItem == taskGroup",
        "group": "navigation@1"
      }
    ]
  },
  "configuration": {
    "properties": {
      "trainning_extension.logsDaysFilter": {
        "type": "number",
        "default": 3,
        "minimum": 1,
        "markdownDescription": "Logs 视图：扫描最近多少天内的 `.onnx` 文件（按文件夹名中的日期判断，默认 3 天）。修改后自动刷新。"
      },
      "trainning_extension.logsScanDepth": {
        "type": "number",
        "default": 5,
        "minimum": 1,
        "maximum": 20,
        "markdownDescription": "Logs 视图：递归扫描的最大目录深度（默认 5 层）。修改后自动刷新。"
      }
    }
  }
}