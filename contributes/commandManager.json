{
  "commands": [
    {
      "command": "trainning_extension.runCommand",
      "title": "Run Command"
    },
    {
      "command": "trainning_extension.openCommandConfig",
      "title": "Edit Config",
      "icon": "$(edit)"
    },
    {
      "command": "trainning_extension.refreshCommands",
      "title": "Refresh Commands",
      "icon": "$(refresh)"
    },
    {
      "command": "trainning_extension.newCommandConfig",
      "title": "New Command Config",
      "icon": "$(add)"
    }
  ],
  "viewsContainers": {
    "activitybar": [
      {
        "id": "trainning_extension",
        "title": "Trainning Extension",
        "icon": "other_files/锤子.svg"
      }
    ]
  },
  "views": {
    "trainning_extension": [
      {
        "id": "trainning_extension_commands",
        "name": "Commands"
      }
    ]
  },
  "menus": {
    "view/title": [
      {
        "command": "trainning_extension.newCommandConfig",
        "when": "view == trainning_extension_commands",
        "group": "navigation"
      },
      {
        "command": "trainning_extension.refreshCommands",
        "when": "view == trainning_extension_commands",
        "group": "navigation"
      }
    ],
    "view/item/context": [
      {
        "command": "trainning_extension.openCommandConfig",
        "when": "view == trainning_extension_commands && viewItem == category",
        "group": "inline"
      }
    ]
  }
}
